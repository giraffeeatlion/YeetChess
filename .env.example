# PostgreSQL Database
POSTGRES_USER=yeetchess
POSTGRES_PASSWORD=yeetchess_dev_password
POSTGRES_DB=yeetchess
DATABASE_URL=postgresql+asyncpg://yeetchess:yeetchess_dev_password@db:5432/yeetchess

# Redis
REDIS_URL=redis://redis:6379

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# JWT & Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development
